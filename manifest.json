{
  "manifest_version": 3,
  "name": "أعماق باقة سيفير (Amaq Baqty Saver)",
  "version": "1.1.0",
  "description": "توفير استهلاك بيانات الإنترنت من خلال التحكم في فيديوهات يوتيوب وفيسبوك. مطورة بواسطة أعماق للتكنولوجيا المعلومات.",
  "author": "أعماق للتكنولوجيا المعلومات",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.facebook.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content_youtube.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://*.facebook.com/*"
      ],
      "js": [
        "content_facebook.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject_youtube.js"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ]
    }
  ]
}